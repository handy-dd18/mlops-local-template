# Copy this file to `.env` and adjust as needed.
# `docker compose` automatically loads `.env` from the project root.

# --- Ports (host side) ---
JUPYTER_PORT=8888
MLFLOW_PORT=5000
FLOCI_PORT=4566

# --- Jupyter ---
# Token required to log into the Jupyter UI at http://localhost:${JUPYTER_PORT}
JUPYTER_TOKEN=mlops

# --- MLflow backend DB (Postgres 16, internal only) ---
MLFLOW_DB_USER=mlflow
MLFLOW_DB_PASSWORD=mlflow
MLFLOW_DB_NAME=mlflow

# --- AWS (Floci emulator) ---
# Floci accepts any non-empty credentials; "test" is the LocalStack convention.
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1

# --- Floci-emulated RDS (populated by Terraform during `make tf-apply`) ---
# RDS_HOST points at the floci service; RDS_PORT is the Floci-assigned RDS proxy port.
RDS_HOST=floci
RDS_PORT=4510
RDS_USER=mlops
RDS_PASSWORD=mlops
RDS_DB=mlops

# --- S3 buckets (created by Terraform) ---
RAW_BUCKET=raw-data
MLFLOW_ARTIFACT_BUCKET=mlflow-artifacts
